# Configuration with API keys and personal data — NEVER commit
config.toml
*.key
*.pem
.env
.env.*

# Generated state (runtime cache)
state.json
state.prev.json

# Compiled binary (rebuild from the in-repo scoring/ package — see scoring/VENDORED.md)
bin/astrowidget-score

# Dart build artifacts for the vendored scoring engine. The source under
# scoring/lib + scoring/bin IS tracked; only the build output + tool cache are
# ignored. scoring/pubspec.lock IS tracked (reproducible builds).
scoring/build/
scoring/.dart_tool/

# Internal development documentation — not part of the distributed product
docs/superpowers/
notes/

# Python build / test artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
.tox/
htmlcov/
*.egg-info/
build/
dist/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
